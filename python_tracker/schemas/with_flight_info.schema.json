{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/with_flight_info.schema.json",
  "title": "Tracking Output With Flight Info",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "metadata",
    "frames",
    "tracks"
  ],
  "properties": {
    "metadata": {
      "type": "object",
      "required": [
        "video_name",
        "width",
        "height",
        "fps",
        "total_frames",
        "flight_info_enrichment",
        "camera",
        "time_offset_sec",
        "opensky_cache_source"
      ],
      "properties": {
        "video_name": {
          "type": "string"
        },
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        },
        "fps": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "total_frames": {
          "type": "integer",
          "minimum": 0
        },
        "source_total_frames": {
          "type": "integer",
          "minimum": 0
        },
        "clip_start_frame": {
          "type": "integer",
          "minimum": 0
        },
        "clip_end_frame": {
          "type": "integer",
          "minimum": 0
        },
        "clip_start_seconds": {
          "type": "number",
          "minimum": 0
        },
        "clip_end_seconds": {
          "type": "number",
          "minimum": 0
        },
        "inference_stride": {
          "type": "integer",
          "minimum": 1
        },
        "contains_interpolated_detections": {
          "type": "boolean"
        },
        "flight_info_enrichment": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "manual_match_count",
            "exported_at"
          ],
          "properties": {
            "manual_match_count": {
              "type": "integer",
              "minimum": 0
            },
            "exported_at": {
              "type": "string"
            }
          }
        },
        "camera": {
          "type": "object",
          "additionalProperties": true
        },
        "time_offset_sec": {
          "type": "number"
        },
        "opensky_cache_source": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "frames": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "frame_index",
          "time_seconds",
          "time_ms",
          "timecode",
          "detections"
        ],
        "properties": {
          "frame_index": {
            "type": "integer",
            "minimum": 0
          },
          "time_seconds": {
            "type": "number",
            "minimum": 0
          },
          "time_ms": {
            "type": "integer",
            "minimum": 0
          },
          "timecode": {
            "type": "string"
          },
          "detections": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "track_id",
                "label",
                "bbox",
                "confidence",
                "flight_info_ref"
              ],
              "properties": {
                "track_id": {
                  "type": "integer",
                  "minimum": 0
                },
                "label": {
                  "type": "string"
                },
                "bbox": {
                  "type": "array",
                  "minItems": 4,
                  "maxItems": 4,
                  "items": {
                    "type": "number"
                  }
                },
                "confidence": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                },
                "interpolated": {
                  "type": "boolean"
                },
                "flight_info_ref": {
                  "type": [
                    "object",
                    "null"
                  ],
                  "additionalProperties": false,
                  "required": [
                    "icao24",
                    "callsign"
                  ],
                  "properties": {
                    "icao24": {
                      "type": "string"
                    },
                    "callsign": {
                      "type": [
                        "string",
                        "null"
                      ]
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "tracks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "track_id",
          "matched",
          "icao24",
          "callsign",
          "candidate_count"
        ],
        "properties": {
          "track_id": {
            "type": "integer",
            "minimum": 0
          },
          "matched": {
            "type": "boolean"
          },
          "icao24": {
            "type": [
              "string",
              "null"
            ]
          },
          "callsign": {
            "type": [
              "string",
              "null"
            ]
          },
          "candidate_count": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    }
  }
}
